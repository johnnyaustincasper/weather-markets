{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "lib",
    "rootDir": "..",
    "strict": true,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "verbatimModuleSyntax": true,
    "types": ["node"]
  },
  "include": [
    "src/**/*.ts",
    "../src/types.ts",
    "../src/services/marketData.ts",
    "../src/services/paperBotLoop.ts",
    "../src/services/paperTrading.ts",
    "../src/services/paperExecutionSettings.ts",
    "../src/services/paperPersistence.ts",
    "../src/lib/firebase.ts",
    "../src/vite-env.d.ts"
  ]
}
